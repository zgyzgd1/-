# Auto detect text files and normalize line endings
* text=auto

# Kotlin / Java
*.kt text eol=lf
*.java text eol=lf

# XML / Resources
*.xml text eol=lf

# Gradle
*.gradle text eol=lf
*.gradle.kts text eol=lf
*.properties text eol=lf

# Scripts
*.sh text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files (no normalization)
*.png binary
*.jpg binary
*.jar binary
